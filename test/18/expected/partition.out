---
--- Test cases for partition-wise GpuJoin/GpuPreAgg
---
SET search_path = public;
SET pg_strom.regression_test_mode = on;
---
--- Simple GPU-Scan (blocked by issue #1026)
---
---
--- Simpe GPU-PreAgg without JOIN
---
explain (costs off)
select sum(lo_extendedprice*lo_discount) as revenue
from plineorder
where lo_orderdate between 19930101 and 19931231
and lo_discount between 1 and 3
and lo_quantity < 25;
                                                                                           QUERY PLAN                                                                                            
-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
 Aggregate
   ->  Gather
         Workers Planned: 2
         ->  Parallel Custom Scan (GpuPreAgg) on plineorder
               GPU Projection: pgstrom.psum((lo_extendedprice * lo_discount))
               referenced: lo_orderdate, lo_quantity, lo_extendedprice, lo_discount
               scan0: plineorder_p1993_heap [plan: 258929 -> 34844]
               scan1: plineorder_p1993_parquet [plan: 260159 -> 2]
               stats-hint1: (lo_orderdate >= 19930101), (lo_orderdate <= 19931231), (lo_discount >= '1'::numeric), (lo_discount <= '3'::numeric), (lo_quantity < '25'::numeric)
               scan2: plineorder_p1993_arrow [plan: 129842 -> 1]
               stats-hint2: (lo_orderdate >= 19930101), (lo_orderdate <= 19931231)
               GPU Scan Quals: ((lo_orderdate >= 19930101) AND (lo_orderdate <= 19931231) AND (lo_discount >= '1'::numeric) AND (lo_discount <= '3'::numeric) AND (lo_quantity < '25'::numeric))
               GPU Group Key: 
               file0: plineorder_p1993_rem1.parquet (read: 2337.33KB, size: 10.40MB)
               file1: plineorder_p1993_rem2.arrow (read: 6593.54KB, size: 21.56MB)
(15 rows)

