---
--- only heap and arrow by partition pruning
---
explain (costs off)
select c_city,s_city,(lo_orderdate/10000)::int d_year,lo_shipmode, sum(lo_revenue) as revenue
  from customer,plineorder,supplier
 where lo_custkey = c_custkey
   and lo_suppkey = s_suppkey
   and (c_city='UNITED KI1' or c_city='UNITED KI5')
   and (s_city='UNITED KI1' or s_city='UNITED KI5')
   and lo_orderdate between 19920701 and 19970630
   and lo_shipmode in ('SHIP','RAIL')
 group by 1,2,3,4
 order by 3 asc, 2 desc;
                                                                       QUERY PLAN                                                                        
---------------------------------------------------------------------------------------------------------------------------------------------------------
 GroupAggregate
   Group Key: ((plineorder.lo_orderdate / 10000)), supplier.s_city, customer.c_city, plineorder.lo_shipmode
   ->  Gather Merge
         Workers Planned: 2
         ->  Sort
               Sort Key: ((plineorder.lo_orderdate / 10000)), supplier.s_city DESC, customer.c_city, plineorder.lo_shipmode
               ->  Hash Join
                     Hash Cond: (plineorder.lo_custkey = customer.c_custkey)
                     ->  Parallel Custom Scan (GpuJoin) on plineorder
                           GPU Projection: lo_orderdate, lo_shipmode, lo_revenue, lo_custkey, s_city
                           referenced: lo_custkey, lo_suppkey, lo_orderdate, lo_revenue
                           scan0: plineorder_p1992_heap [plan: 133225 -> 64784]
                           brin0: (lo_orderdate >= 19920701), (lo_orderdate <= 19970630)
                           scan1: plineorder_p1992_arrow [plan: 129997 -> 6]
                           stats-hint1: (lo_orderdate <= 19970630), (lo_orderdate >= 19920701)
                           scan2: plineorder_p1993_heap [plan: 258929 -> 129630]
                           scan3: plineorder_p1993_arrow [plan: 129842 -> 6]
                           stats-hint3: (lo_orderdate <= 19970630), (lo_orderdate >= 19920701)
                           scan4: plineorder_p1994_heap [plan: 260127 -> 129397]
                           scan5: plineorder_p1994_arrow [plan: 130326 -> 7]
                           stats-hint5: (lo_orderdate <= 19970630), (lo_orderdate >= 19920701)
                           scan6: plineorder_p1995_heap [plan: 261110 -> 130199]
                           scan7: plineorder_p1995_arrow [plan: 130678 -> 7]
                           stats-hint7: (lo_orderdate <= 19970630), (lo_orderdate >= 19920701)
                           scan8: plineorder_p1996_heap [plan: 261196 -> 130530]
                           scan9: plineorder_p1996_arrow [plan: 130699 -> 7]
                           stats-hint9: (lo_orderdate <= 19970630), (lo_orderdate >= 19920701)
                           scan10: plineorder_p1997_heap [plan: 130298 -> 63567]
                           brin10: (lo_orderdate >= 19920701), (lo_orderdate <= 19970630)
                           scan11: plineorder_p1997_arrow [plan: 129585 -> 6]
                           stats-hint11: (lo_orderdate <= 19970630), (lo_orderdate >= 19920701)
                           GPU Scan Quals: ((lo_shipmode = ANY ('{SHIP,RAIL}'::bpchar[])) AND (lo_orderdate <= 19970630) AND (lo_orderdate >= 19920701))
                           GPU Join Quals [1]: (lo_suppkey = s_suppkey)
                           GPU Outer Hash [1]: lo_suppkey
                           GPU Inner Hash [1]: s_suppkey
                           file0: plineorder_p1992_rem2.arrow (read: 4824.11KB, size: 21.58MB)
                           file1: plineorder_p1993_rem2.arrow (read: 4818.36KB, size: 21.56MB)
                               :                 :                       :
                           file4: plineorder_p1996_rem2.arrow (read: 4850.16KB, size: 21.70MB)
                           file5: plineorder_p1997_rem2.arrow (read: 4808.82KB, size: 21.51MB)
                           ->  Parallel Seq Scan on supplier
                                 Filter: ((s_city = 'UNITED KI1'::bpchar) OR (s_city = 'UNITED KI5'::bpchar))
                     ->  Hash
                           ->  Custom Scan (GpuScan) on customer
                                 GPU Projection: c_city, c_custkey
                                 GPU Scan Quals: ((c_city = 'UNITED KI1'::bpchar) OR (c_city = 'UNITED KI5'::bpchar))
