---
--- GPU-PreAgg with JOIN
---
explain (costs off)
select c_city,s_city,(lo_orderdate/10000)::int d_year,sum(lo_revenue) as revenue
  from customer,plineorder,supplier
 where lo_custkey = c_custkey
   and lo_suppkey = s_suppkey
   and (c_city='UNITED KI1' or c_city='UNITED KI5')
   and (s_city='UNITED KI1' or s_city='UNITED KI5')
   and lo_orderdate between 19930701 and 19960630
 group by 1,2,3
 order by 3 asc, 2 desc;
                                                      QUERY PLAN                                                      
----------------------------------------------------------------------------------------------------------------------
 GroupAggregate
   Group Key: ((plineorder.lo_orderdate / 10000)), supplier.s_city, customer.c_city
   ->  Gather Merge
         Workers Planned: 2
         ->  Sort
               Sort Key: ((plineorder.lo_orderdate / 10000)), supplier.s_city DESC, customer.c_city
               ->  Hash Join
                     Hash Cond: (plineorder.lo_custkey = customer.c_custkey)
                     ->  Parallel Custom Scan (GpuJoin) on plineorder
                           GPU Projection: lo_orderdate, lo_revenue, lo_custkey, s_city
                           referenced: lo_custkey, lo_suppkey, lo_orderdate, lo_revenue
                           scan0: plineorder_p1993_heap [plan: 133147 -> 130200]
                           brin0: (lo_orderdate >= 19930701), (lo_orderdate <= 19960630)
                           scan1: plineorder_p1993_parquet [plan: 260159 -> 1301]
                           stats-hint1: (lo_orderdate >= 19930701), (lo_orderdate <= 19960630)
                           scan2: plineorder_p1993_arrow [plan: 129842 -> 649]
                           stats-hint2: (lo_orderdate >= 19930701), (lo_orderdate <= 19960630)
                           scan3: plineorder_p1994_heap [plan: 260127 -> 260077]
                           scan4: plineorder_p1994_parquet [plan: 260284 -> 1301]
                           stats-hint4: (lo_orderdate >= 19930701), (lo_orderdate <= 19960630)
                           scan5: plineorder_p1994_arrow [plan: 130326 -> 652]
                           stats-hint5: (lo_orderdate >= 19930701), (lo_orderdate <= 19960630)
                           scan6: plineorder_p1995_heap [plan: 261110 -> 261059]
                           scan7: plineorder_p1995_parquet [plan: 261026 -> 1305]
                           stats-hint7: (lo_orderdate >= 19930701), (lo_orderdate <= 19960630)
                           scan8: plineorder_p1995_arrow [plan: 130678 -> 653]
                           stats-hint8: (lo_orderdate >= 19930701), (lo_orderdate <= 19960630)
                           scan9: plineorder_p1996_heap [plan: 130598 -> 127710]
                           brin9: (lo_orderdate >= 19930701), (lo_orderdate <= 19960630)
                           scan10: plineorder_p1996_parquet [plan: 261481 -> 1307]
                           stats-hint10: (lo_orderdate >= 19930701), (lo_orderdate <= 19960630)
                           scan11: plineorder_p1996_arrow [plan: 130699 -> 653]
                           stats-hint11: (lo_orderdate >= 19930701), (lo_orderdate <= 19960630)
                           GPU Scan Quals: ((lo_orderdate >= 19930701) AND (lo_orderdate <= 19960630))
                           GPU Join Quals [1]: (lo_suppkey = s_suppkey)
                           GPU Outer Hash [1]: lo_suppkey
                           GPU Inner Hash [1]: s_suppkey
                           file0: plineorder_p1993_rem1.parquet (read: 3336.79KB, size: 10.40MB)
                           file1: plineorder_p1993_rem2.arrow (read: 3550.37KB, size: 21.56MB)
                               :                 :                       :
                           file6: plineorder_p1996_rem1.parquet (read: 3353.48KB, size: 10.46MB)
                           file7: plineorder_p1996_rem2.arrow (read: 3573.80KB, size: 21.70MB)
                           ->  Parallel Seq Scan on supplier
                                 Filter: ((s_city = 'UNITED KI1'::bpchar) OR (s_city = 'UNITED KI5'::bpchar))
                     ->  Hash
                           ->  Custom Scan (GpuScan) on customer
                                 GPU Projection: c_city, c_custkey
                                 GPU Scan Quals: ((c_city = 'UNITED KI1'::bpchar) OR (c_city = 'UNITED KI5'::bpchar))
